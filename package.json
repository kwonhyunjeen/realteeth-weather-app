{
  "name": "weather-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "lefthook install --reset-hooks-path",
    "dev": "run-p dev:vite dev:tsc",
    "dev:vite": "vercel dev",
    "dev:tsc": "tsc -b tsconfig.app.json tsconfig.node.json --watch --preserveWatchOutput",
    "build": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@suspensive/react": "^3.21.1",
    "@suspensive/react-query": "^3.21.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.9",
    "es-hangul": "^2.3.8",
    "lucide-react": "^1.14.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vercel": "^53.3.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
